---
import Times from "@packages/acore-ts/data/date/constants/Times";
import Container from "../../../../../Container";

<div class="flex items-center justify-end gap-6 text-nowrap text-white select-none">
  <span id="clock"> 09:05:00 </span>
  <span id="date" class="hidden sm:block">
    10 Kasım 193<span class="text-xl">∞</span>
  </span>
</div>

<script>
  import Times from "@packages/acore-ts/data/date/constants/Times";
  import Container from "../../../../../Container";

  let clockInterval = null;
  
  function onMount() {
    // Clear previous clock if exists
    if (clockInterval) {
      clearTimeout(clockInterval);
      clockInterval = null;
    }
    
    const clockContainer = document.querySelector("#clock");
    const dateContainer = document.querySelector("#date");

    const i18n = Container.instance.i18n;
    const locale = i18n.getLocaleFromUrl(window.location.href, "en");

    const now = new Date();
    updateClock(now);
    updateDate(now);
    scheduleNextUpdate();

    function updateClock(now) {
      const hour = now.getHours();
      const minute = now.getMinutes();
      clockContainer.textContent = `${hour.toString().padStart(2, "0")}:${minute.toString().padStart(2, "0")}:${now.getSeconds().toString().padStart(2, "0")}`;
    }

    function updateDate(now) {
      dateContainer.textContent = now.toLocaleString(locale, {
        year: "numeric",
        month: "long",
        day: "2-digit",
        weekday: "long",
      });
    }

    function scheduleNextUpdate(nextTimeout) {
      if (!nextTimeout) nextTimeout = Times.MILLIS_IN_SECOND - new Date().getMilliseconds();
      clockInterval = setTimeout(() => {
        const now = new Date();
        updateClock(now);
        // Update date every minute when seconds roll over to 00
        if (now.getSeconds() === 0) updateDate(now);

        scheduleNextUpdate(Times.MILLIS_IN_SECOND);
      }, nextTimeout);
    }
  }

  // Run immediately on initial load AND after Astro view transitions
  onMount();
  document.addEventListener("astro:after-swap", onMount);
</script>
